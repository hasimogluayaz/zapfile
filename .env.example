# ZapFile Environment Variables
# Copy this file to .env.local and fill in the values

# Google AdSense (optional - add when approved)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL (used for sitemap & OG tags)
# Use www to match Vercel primary domain (avoids GSC sitemap fetch issues on apex redirect)
NEXT_PUBLIC_SITE_URL=https://www.zapfile.xyz
