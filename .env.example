# ZapFile Environment Variables
# Copy this file to .env.local and fill in the values

# Google AdSense (optional - add when approved)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL (used for sitemap & OG tags)
# Must match the Google Search Console property domain (https://zapfile.xyz/)
NEXT_PUBLIC_SITE_URL=https://zapfile.xyz
